{
  "name": "martin-wysiecki-homepage",
  "version": "1.0.0",
  "description": "Modern portfolio homepage for Martin von Wysiecki",
  "type": "module",
  "scripts": {
    "dev": "npx tailwindcss -i ./src/css/input.css -o ./dist/output.css --watch",
    "build": "mkdir -p dist && npx tailwindcss -i ./src/css/input.css -o ./dist/output.css --minify",
    "lint": "eslint src/js/*.js",
    "format": "prettier --write 'src/**/*.{html,js,css}' '*.{js,json}'",
    "format:check": "prettier --check 'src/**/*.{html,js,css}' '*.{js,json}'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0"
  }
}
